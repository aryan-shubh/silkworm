DATABASE_URL=postgresql://user:pass@host.psdb.cloud:5432/postgres?sslmode=require

# Override the marketing-page demo run ID (defaults to "demo-run-1")
DEMO_RUN_ID=

# --- Composio (OAuth broker for sign-in) ---
COMPOSIO_API_KEY=
# Composio Auth Config ID for the GitHub OAuth integration (from Composio dashboard).
COMPOSIO_GITHUB_AUTH_CONFIG_ID=

# --- Session cookies ---
# 32+ random characters; used to sign the session cookie.
SESSION_SECRET=replace-with-32-char-random-string

# --- Upstash Redis (optional; query cache + session store fall through if absent) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
